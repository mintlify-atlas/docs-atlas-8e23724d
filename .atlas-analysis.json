  "keyFeatures": [
    "Automated data profiling that scans table groups and generates column-level statistics",
    "AI-assisted test generation producing hundreds of data quality checks from profiling results",
    "Continuous anomaly monitoring tracking freshness, volume, schema drift, and custom metrics",
    "Web-based dashboard for reviewing profiling, test results, and hygiene issues",
    "CLI and MCP server for automation, scripting, and AI-agent integration",
    "Multi-database support: PostgreSQL, Snowflake, Redshift, MSSQL, Databricks, BigQuery, Trino, SAP HANA, Oracle",
    "Docker Compose deployment via dk-installer for easy self-hosted setup",
    "Export to DataOps Observability for broader pipeline health monitoring",
    "Built-in scheduler for automated recurring profiling and test runs",
    "Score cards and quality dashboards with drill-down into failed tests"
  ],
  "publicApiSurface": [
